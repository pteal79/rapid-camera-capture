{
    "name": "pteal79/rapid-camera-capture",
    "description": "A NativePHP plugin for persistent camera capture — take multiple photos in one session, saved to mobile_public disk with UUID filenames.",
    "type": "nativephp-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "PTeal79",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PTeal79\\RapidCameraCapture\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PTeal79\\RapidCameraCapture\\RapidCameraCaptureServiceProvider"
            ]
        },
        "nativephp": {
            "manifest": "nativephp.json"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
